<Window x:Class="SATUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:SATUI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="768" Width="1280"
        MinHeight="400" MinWidth="600"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Icon="Resources/satellite.ico">

    <Window.InputBindings>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding NavigateCommand}"/>
        <KeyBinding Key="S" Modifiers="Alt" Command="{Binding OpenSettingsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Height="36" Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Stretch" Margin="4,0">

                <!-- App logo (left) -->
                <TextBlock DockPanel.Dock="Left"
                           Text="📡 SATUI" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppText}"
                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                <Rectangle DockPanel.Dock="Left" Width="1" Fill="{DynamicResource AppBorder}"
                           VerticalAlignment="Stretch" Margin="0,6"/>

                <!-- Gear icon (far right) -->
                <Button DockPanel.Dock="Right"
                        Content="⚙" Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="Settings (Alt+S)" Width="32"/>

                <!-- Reload button (to the left of the gear) -->
                <Button DockPanel.Dock="Right"
                        Content="⟳" Command="{Binding NavigateCommand}"
                        Style="{StaticResource HeaderIconButton}"
                        ToolTip="Reload (Ctrl+R)" Width="32" Margin="0,0,2,0"/>

                <Rectangle DockPanel.Dock="Right" Width="1" Fill="{DynamicResource AppBorder}"
                           VerticalAlignment="Stretch" Margin="4,6"/>

                <!-- Clickable URL (fills remaining space) -->
                <Button Content="{Binding CurrentUrl}"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource HeaderUrlButton}"
                        ToolTip="Click to configure URL"/>

            </DockPanel>
        </Border>

        <!-- WebView2 content (fills row; error/loading shown via dialogs/overlay) -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <!-- Loading indicator -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource AppOverlay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Connecting…" FontSize="18" Foreground="{DynamicResource AppText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
