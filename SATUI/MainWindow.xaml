<Window x:Class="SATUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:SATUI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="768" Width="1280"
        MinHeight="400" MinWidth="600"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Icon="Resources/satellite.ico">

    <Window.InputBindings>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding NavigateCommand}"/>
        <KeyBinding Key="S" Modifiers="Alt" Command="{Binding OpenSettingsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Height="36" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource AppText}">
            <TextBlock Text="📡 SATUI" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" VerticalAlignment="Center" Margin="4,0,12,0"/>
            <Separator/>
            <TextBlock Text="{Binding CurrentUrl}" FontSize="12" Foreground="{DynamicResource AppTextMuted}"
                       VerticalAlignment="Center" Margin="4,0" MaxWidth="600"
                       TextTrimming="CharacterEllipsis"/>
            <Separator/>
            <Button Content="⟳ Reload" Command="{Binding NavigateCommand}"
                    ToolTip="Reload (Ctrl+R)" Margin="4,0"/>
            <Button Content="⚙ Settings" Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings (Alt+S)" Margin="4,0"/>
        </ToolBar>

        <!-- WebView2 content (fills row; error/loading shown via dialogs/overlay) -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <!-- Loading indicator -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource AppOverlay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Connecting…" FontSize="18" Foreground="{DynamicResource AppText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
